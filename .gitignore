@'
# Dependencies
node_modules/
server/node_modules/

# Build output
dist/
build/

# Environment variables
.env
.env.local
.env.production

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/

# MongoDB data
mongo-data/
'@ | Out-File -FilePath .gitignore -Encoding UTF8